{% if newsletter %}
  <section class="newsletter-block">
    <div class="container newsletter-block__inner">
      <div>
        <div class="eyebrow with-rule">{{ 'The weekly dispatch'|t }}</div>
        <h2>{{ 'A small, useful letter on cooking and the season.'|t }}</h2>
        <p>{{ 'Sent Sunday mornings. One recipe, one short essay, and a few things we have been eating.'|t }}</p>
      </div>
      <div>{{ newsletter }}</div>
    </div>
  </section>
{% endif %}
