<section class="container page-hero">
  <div class="eyebrow with-rule">{{ 'Search'|t }}</div>
  <h1>{{ 'Look in every cupboard.'|t }}</h1>
  <form method="get" action="{{ path('umami_next.search') }}" class="search-form search-form--inline">
    <input type="search" name="q" value="{{ query }}" placeholder="{{ 'recipes, essays, anything...'|t }}">
  </form>
</section>

<section class="container">
  <div class="chips archive-chips">
    <a href="{{ path('umami_next.search', {}, {'query': query ? {'q': query} : {}}) }}" class="chip {{ type == '' ? 'is-active' : '' }}">{{ 'All'|t }}</a>
    <a href="{{ path('umami_next.search', {}, {'query': query ? {'q': query, 'type': 'recipe'} : {'type': 'recipe'}}) }}" class="chip {{ type == 'recipe' ? 'is-active' : '' }}">{{ 'Recipes'|t }}</a>
    <a href="{{ path('umami_next.search', {}, {'query': query ? {'q': query, 'type': 'article'} : {'type': 'article'}}) }}" class="chip {{ type == 'article' ? 'is-active' : '' }}">{{ 'Stories'|t }}</a>
    <a href="{{ path('umami_next.search', {}, {'query': query ? {'q': query, 'type': 'collection'} : {'type': 'collection'}}) }}" class="chip {{ type == 'collection' ? 'is-active' : '' }}">{{ 'Collections'|t }}</a>
  </div>
  <div class="results-count">
    {% if query %}
      {{ result_count }} {{ 'results for'|t }} “{{ query }}”
    {% else %}
      {{ result_count }} {{ 'pieces across Umami'|t }}
    {% endif %}
  </div>
  {% if results %}
    <div class="search-results">
      {% for result in results %}
        <a href="{{ result.url }}" class="search-result">
          {% if result.image.url %}
            <div class="search-result__image"><img src="{{ result.image.url }}" alt="{{ result.image.alt }}"></div>
          {% else %}
            <div class="search-result__image card-media--placeholder" aria-hidden="true"></div>
          {% endif %}
          <div>
            <div class="eyebrow">{{ result.type|title }}</div>
            <h3 class="search-result__title">{{ result.title }}</h3>
            <p class="card__deck">{{ result.summary }}</p>
          </div>
          <div class="search-result__cta">{{ 'Read'|t }} &rarr;</div>
        </a>
      {% endfor %}
    </div>
    {{ pager }}
  {% else %}
    <div class="empty"><h3>{{ query ? 'No matches.'|t : 'Start with a search term.'|t }}</h3></div>
  {% endif %}
</section>
