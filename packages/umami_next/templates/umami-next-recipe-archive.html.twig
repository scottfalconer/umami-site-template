<section class="container archive-hero">
  <div class="eyebrow with-rule">{{ 'Recipe index'|t }}</div>
  <h1 class="archive-title">Recipes, by <em>season</em> and <em>supper</em>.</h1>
  <p class="archive-deck">{{ 'Filter by course, dietary, or cuisine. All recipes are tested in a real home kitchen.'|t }}</p>
</section>

<section class="container">
  <div class="filter-bar">
    <div class="filter-bar__groups">
      {% for filter_name, options in filters %}
        <div class="filter-bar__group">
          <span class="filter-bar__label">{{ filter_name|replace({'_': ' '})|title }}</span>
          <div class="filter-bar__chips">
            {% for option in options %}
              <a href="{{ path('umami_next.recipes', {}, {'query': active_filters|merge({(filter_name): option.slug})}) }}" class="chip {{ active_filters[filter_name] == option.slug ? 'is-active' : '' }}">{{ option.label }}</a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="results-count">{{ cards ? cards|length : 0 }} {{ 'results'|t }}</div>
  {% if cards %}
    <div class="grid-4">
      {% for card in cards %}
        <a href="{{ card.url }}" class="card">
          {% if card.image.url %}
          <div class="card-media"><img src="{{ card.image.url }}" alt="{{ card.image.alt }}"></div>
        {% else %}
          <div class="card-media card-media--placeholder" aria-hidden="true"></div>
        {% endif %}
          <div class="card__meta"><span>{{ card.category }}</span></div>
          <h3 class="card__title">{{ card.title }}</h3>
          <p class="card__deck">{{ card.summary }}</p>
        </a>
      {% endfor %}
    </div>
    {{ pager }}
  {% else %}
    <div class="empty"><h3>{{ 'Nothing in this filter yet.'|t }}</h3></div>
  {% endif %}
</section>
