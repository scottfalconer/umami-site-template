<section class="container archive-hero">
  <div class="eyebrow with-rule">{{ 'Essays'|t }}</div>
  <h1 class="archive-title">Stories from the <em>kitchen</em>.</h1>
  <p class="archive-deck">{{ 'Short essays on technique, ingredients, heritage, and the small politics of dinner.'|t }}</p>
</section>

<section class="container">
  <div class="chips archive-chips">
    <a href="{{ path('umami_next.stories') }}" class="chip {{ active_topic == '' ? 'is-active' : '' }}">{{ 'All'|t }}</a>
    {% for topic in topics %}
      <a href="{{ path('umami_next.stories', {}, {'query': {'topic': topic.slug}}) }}" class="chip {{ active_topic == topic.slug ? 'is-active' : '' }}">{{ topic.label }}</a>
    {% endfor %}
  </div>
  {% if cards %}
    <div class="grid-3">
      {% for card in cards %}
        <a href="{{ card.url }}" class="card">
          {% if card.image.url %}
          <div class="card-media"><img src="{{ card.image.url }}" alt="{{ card.image.alt }}"></div>
        {% else %}
          <div class="card-media card-media--placeholder" aria-hidden="true"></div>
        {% endif %}
          <div class="card__meta"><span>{{ card.topic }}</span></div>
          <h3 class="card__title">{{ card.title }}</h3>
          <p class="card__deck">{{ card.summary }}</p>
        </a>
      {% endfor %}
    </div>
    {{ pager }}
  {% else %}
    <div class="empty"><h3>{{ 'No stories yet.'|t }}</h3></div>
  {% endif %}
</section>
