<section class="container topic-hero">
  <div class="eyebrow">{{ 'Topic'|t }}</div>
  <h1 class="topic-hero__title">{{ topic.label }}</h1>
  <p class="topic-hero__intro">
    {{ recipe_count }} {{ recipe_count == 1 ? 'recipe'|t : 'recipes'|t }} {{ 'tagged'|t }}
    {{ 'and'|t }} {{ article_count }} {{ article_count == 1 ? 'essay'|t : 'essays'|t }} {{ 'tagged'|t }}
    <em>{{ topic.label|lower }}</em>. {{ 'Everything on this page is gathered through shared topic terms so editors can keep the archive coherent as the journal grows.'|t }}
  </p>
</section>

{% if article_cards %}
  <section class="container section-space">
    <div class="section-heading">
      <div>
        <div class="eyebrow">{{ 'From the journal'|t }}</div>
        <h2 class="section-heading__title">{{ 'Essays'|t }}</h2>
      </div>
    </div>
    <div class="topic-story-grid">
      {% for card in article_cards %}
        <a href="{{ card.url }}" class="card">
          {% if card.image.url %}
          <div class="card-media"><img src="{{ card.image.url }}" alt="{{ card.image.alt }}"></div>
        {% else %}
          <div class="card-media card-media--placeholder" aria-hidden="true"></div>
        {% endif %}
          <div class="card__meta">
            <span>{{ 'Essay'|t }}</span>
            {% if card.topic %}<span class="dot">•</span><span>{{ card.topic }}</span>{% endif %}
          </div>
          <h3 class="card__title">{{ card.title }}</h3>
          <p class="card__deck">{{ card.summary }}</p>
          <div class="card__meta">
            {% if card.author %}<span>{{ card.author.name }}</span><span class="dot">•</span>{% endif %}
            <span>{{ card.date }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}

<section class="container section-space">
  <div class="section-heading">
    <div>
      <div class="eyebrow">{{ 'Recipes'|t }}</div>
      <h2 class="section-heading__title">{{ 'Recipes in this topic'|t }}</h2>
    </div>
  </div>
  {% if recipe_cards %}
    <div class="grid-4">
      {% for card in recipe_cards %}
        <a href="{{ card.url }}" class="card">
          {% if card.image.url %}
          <div class="card-media"><img src="{{ card.image.url }}" alt="{{ card.image.alt }}"></div>
        {% else %}
          <div class="card-media card-media--placeholder" aria-hidden="true"></div>
        {% endif %}
          <div class="card__meta">
            {% if card.category %}<span>{{ card.category }}</span><span class="dot">•</span>{% endif %}
            {% if card.cuisine %}<span>{{ card.cuisine }}</span>{% endif %}
          </div>
          <h3 class="card__title">{{ card.title }}</h3>
          <p class="card__deck">{{ card.summary }}</p>
          <div class="card__meta">
            {% if card.total %}<span>{{ card.total }} {{ 'min'|t }}</span><span class="dot">•</span>{% endif %}
            {% if card.difficulty %}<span>{{ card.difficulty }}</span><span class="dot">•</span>{% endif %}
            {% if card.servings %}<span>{{ 'Serves'|t }} {{ card.servings }}</span>{% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  {% else %}
    <div class="empty"><h3>{{ 'Nothing here yet.'|t }}</h3></div>
  {% endif %}
</section>

{% if newsletter_form %}
  <section class="newsletter-block">
    <div class="container newsletter-block__inner">
      <div>
        <div class="eyebrow with-rule">{{ 'The weekly dispatch'|t }}</div>
        <h2>{{ 'A small, useful letter on cooking and the season.'|t }}</h2>
        <p>{{ 'Sent Sunday mornings. One recipe, one short essay, and a few things we have been eating. No noise.'|t }}</p>
      </div>
      <div>{{ newsletter_form }}</div>
    </div>
  </section>
{% endif %}
