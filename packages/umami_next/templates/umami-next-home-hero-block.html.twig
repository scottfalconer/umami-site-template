<section class="container hero">
  <div class="hero-grid">
    <div>
      <div class="hero-eyebrow with-rule">{{ issue_label }}</div>
      <h1 class="hero-title">{{ headline_prefix }} <em>{{ headline_emphasis }}</em> {{ headline_suffix }}</h1>
      {% if hero %}
        <p class="hero-deck">{{ hero.summary }}</p>
      {% endif %}
      <div class="hero-meta">
        {% if hero_author %}
          <div class="byline">
            {% if hero_author.image %}
              <div class="byline__avatar"><img src="{{ hero_author.image }}" alt="{{ hero_author.name }}"></div>
            {% endif %}
            <span>{{ 'By'|t }} <span class="name">{{ hero_author.name }}</span></span>
          </div>
        {% endif %}
        {% if hero %}
          <a class="btn btn--ghost" href="{{ hero.url }}">{{ cta_label }}</a>
        {% endif %}
      </div>
    </div>
    {% if hero and hero.image.url %}
      <div>
        <div class="hero-media"><img src="{{ hero.image.url }}" alt="{{ hero.image.alt }}"></div>
        <div class="hero-caption">{{ image_caption }}</div>
      </div>
    {% endif %}
  </div>
</section>
