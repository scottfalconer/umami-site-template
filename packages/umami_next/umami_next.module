      'template' => 'umami-next-contact',
    ],
    'umami_next_not_found' => [
      'variables' => [
        'recipe_cards' => [],
        'headline' => '',
        'description' => '',
        'home_label' => '',
        'recipes_label' => '',
      ],
      'template' => 'umami-next-not-found',
    ],
    'umami_next_home_hero_block' => [
      'variables' => [
        'hero' => NULL,
        'hero_author' => NULL,
        'issue_label' => '',
        'headline_prefix' => '',
        'headline_emphasis' => '',
        'headline_suffix' => '',
        'cta_label' => '',
        'image_caption' => '',
      ],
      'template' => 'umami-next-home-hero-block',
    ],
    'umami_next_featured_recipes_block' => [
      'variables' => [
        'featured_recipes' => [],
        'eyebrow' => '',
        'section_title' => '',
        'cta_label' => '',
      ],
      'template' => 'umami-next-featured-recipes-block',
    ],
    'umami_next_spotlight_collection_block' => [
      'variables' => [
        'spotlight' => NULL,
        'eyebrow' => '',
        'cta_label' => '',
      ],
      'template' => 'umami-next-spotlight-collection-block',
    ],
    'umami_next_topic_browse_block' => [
