      ],
      'template' => 'umami-next-promo-strip-block',
    ],
  ];
}

/**
 * Implements hook_entity_insert().
 */
function umami_next_entity_insert(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() === 'node') {
    _umami_next_backfill_default_content_node_references();
  }
}

/**
 * Restores circular node references after default content import.
 *
 * Drupal core's default content importer resolves entity reference fields only
 * when the referenced entity is already available in the current dependency
 * graph. Umami recipes intentionally cross-reference one another, so this keeps
 * those exported relationships deterministic on clean installs.
 */
function _umami_next_backfill_default_content_node_references(): void {
  static $running = FALSE;

  if ($running || \Drupal::state()->get('umami_next.default_content_references_backfilled')) {
    return;
  }

  $running = TRUE;
  try {
    $reference_map = \Drupal::config('umami_next.default_content_references')->get('node_references') ?? [];
    if (!$reference_map) {
      return;
    }

    $repository = \Drupal::service('entity.repository');
    $required_uuids = array_keys($reference_map);
    foreach ($reference_map as $fields) {
      foreach ($fields as $target_uuids) {
        array_push($required_uuids, ...$target_uuids);
      }
    }

    foreach (array_unique($required_uuids) as $uuid) {
      if (!$repository->loadEntityByUuid('node', $uuid) instanceof NodeInterface) {
        return;
      }
    }

    foreach ($reference_map as $source_uuid => $fields) {
      $source = $repository->loadEntityByUuid('node', $source_uuid);
      if (!$source instanceof NodeInterface) {
        continue;
      }

      $changed = FALSE;
      foreach ($fields as $field_name => $target_uuids) {
        if (!$source->hasField($field_name)) {
          continue;
        }

        $target_ids = [];
        foreach ($target_uuids as $target_uuid) {
          $target = $repository->loadEntityByUuid('node', $target_uuid);
          if (!$target instanceof NodeInterface) {
            continue 2;
          }
          $target_ids[] = (int) $target->id();
        }

        $current_ids = array_map(
          static fn (array $item): int => (int) ($item['target_id'] ?? 0),
          $source->get($field_name)->getValue(),
        );
        if ($current_ids !== $target_ids) {
          $source->set($field_name, array_map(
            static fn (int $target_id): array => ['target_id' => $target_id],
            $target_ids,
          ));
          $changed = TRUE;
        }
      }

      if ($changed) {
        $source->setSyncing(TRUE);
        $source->save();
      }
    }

    \Drupal::state()->set('umami_next.default_content_references_backfilled', TRUE);
  }
  finally {
    $running = FALSE;
  }
}
