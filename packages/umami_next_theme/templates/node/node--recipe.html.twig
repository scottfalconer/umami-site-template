<article{{ attributes.addClass('recipe-layout', 'container') }}>
  <header class="detail-hero">
    <div>
      <div class="eyebrow with-rule">{{ umami_recipe.category }}{% if umami_recipe.cuisine %} · {{ umami_recipe.cuisine }}{% endif %}</div>
      <h1 class="detail-title">{{ label }}</h1>
      {% if node.field_description.value %}
        <p class="detail-deck">{{ node.field_description.value }}</p>
      {% endif %}
      <div class="hero-meta">
        {% if umami_author %}
          <div class="byline">
            {% if umami_author.image %}
              <div class="byline__avatar"><img src="{{ umami_author.image }}" alt="{{ umami_author.name }}"></div>
            {% endif %}
            <span>{{ 'By'|t }} <span class="name">{{ umami_author.name }}</span></span>
            {% if umami_author.role %}
              <span class="dot">&middot;</span><span>{{ umami_author.role }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
      {% if umami_recipe.recipe_credit %}
        <p class="provenance-note">{{ umami_recipe.recipe_credit }}</p>
      {% endif %}
    </div>
    {% if content.field_featured_image %}
      <figure class="detail-hero__figure">
        <div class="detail-hero__image">{{ content.field_featured_image }}</div>
        {% if umami_recipe.credit %}
          <figcaption class="media-credit">{{ 'Photo:'|t }} {{ umami_recipe.credit }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}
  </header>

  <section class="meta-panel">
    <div class="meta-item"><div class="meta-item__label">{{ 'Prep'|t }}</div><div class="meta-item__value">{{ umami_recipe.prep }} min</div></div>
    <div class="meta-item"><div class="meta-item__label">{{ 'Cook'|t }}</div><div class="meta-item__value">{{ umami_recipe.cook }} min</div></div>
    <div class="meta-item"><div class="meta-item__label">{{ 'Serves'|t }}</div><div class="meta-item__value">{{ umami_recipe.servings }}</div></div>
    <div class="meta-item"><div class="meta-item__label">{{ 'Difficulty'|t }}</div><div class="meta-item__value">{{ umami_recipe.difficulty }}</div></div>
  </section>

  <div class="recipe-columns">
    <aside class="ingredients">
      <h2>{{ 'Ingredients'|t }}</h2>
      {% for group in umami_recipe.ingredients %}
        <div class="ingredients__group">
          {% if group.label %}
            <div class="ingredients__label">{{ group.label }}</div>
          {% endif %}
          <ul>
            {% for item in group.items %}
              <li><span class="ingredients__qty">{{ item.qty }}</span><span>{{ item.name }}</span></li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
      {% if umami_recipe.topics %}
        <div class="ingredients__group">
          <div class="ingredients__label">{{ 'Topics'|t }}</div>
          <div class="chips">
            {% for topic in umami_recipe.topics %}
              <a href="{{ topic.url }}" class="chip">{{ topic.label }}</a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </aside>
    <div class="steps">
      <h2>{{ 'Method'|t }}</h2>
      <ol>
        {% for step in umami_recipe.steps %}
          <li>
            <div>
              <div class="step-title">{{ step.title }}</div>
              <div>{{ step.body }}</div>
            </div>
          </li>
        {% endfor %}
      </ol>
      {% if umami_recipe.notes %}
        <div class="note-callout">
          <div class="eyebrow">{{ 'A small note'|t }}</div>
          <p>{{ umami_recipe.notes }}</p>
        </div>
      {% endif %}
    </div>
  </div>

  {% if umami_recipe.related_recipes %}
    <section class="section-space">
      <div class="section-heading">
        <div>
          <div class="eyebrow">{{ 'More like this'|t }}</div>
          <h2 class="section-heading__title">{{ 'More like this'|t }}</h2>
        </div>
      </div>
      <div class="grid-3">
        {% for card in umami_recipe.related_recipes %}
          <a href="{{ card.url }}" class="card">
            {% if card.image.url %}
          <div class="card-media"><img src="{{ card.image.url }}" alt=""></div>
        {% else %}
          <div class="card-media card-media--placeholder" aria-hidden="true"></div>
        {% endif %}
            <div class="card__meta"><span>{{ card.category }}</span>{% if card.cuisine %}<span class="dot">&middot;</span><span>{{ card.cuisine }}</span>{% endif %}</div>
            <h3 class="card__title">{{ card.title }}</h3>
            <p class="card__deck">{{ card.summary }}</p>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if umami_recipe.newsletter_form %}
    <section class="newsletter-block section-space">
      <div class="newsletter-block__inner">
        <div>
          <div class="eyebrow with-rule">{{ 'The weekly dispatch'|t }}</div>
          <h2>{{ 'A small, useful letter on cooking and the season.'|t }}</h2>
          <p>{{ 'Sent Sunday mornings. One recipe, one short essay, and a few things we have been eating. No noise.'|t }}</p>
        </div>
        <div class="newsletter-block__form">
          {{ umami_recipe.newsletter_form }}
        </div>
      </div>
    </section>
  {% endif %}
</article>
