<div class="layout-container">
  <header class="site-header">
    {% if page.pre_header %}
      <div class="announce-strip">
        <div class="container">
          {{ page.pre_header }}
        </div>
      </div>
    {% endif %}
    <div class="container site-header__inner">
      <nav class="site-header__nav" aria-label="{{ 'Primary'|t }}">
        {% for item in umami_main_menu|slice(0, 3) %}
          <a href="{{ item.url }}" class="{{ item.active ? 'is-active' : '' }}">{{ item.title }}</a>
        {% endfor %}
      </nav>
      <a href="{{ path('<front>') }}" class="site-header__logo">
        <span>{{ site_name }}</span><span class="dot"></span>
      </a>
      <div class="site-header__tools">
        {% for item in umami_main_menu|slice(3) %}
          {% if item.title != 'Contact' %}
            <a href="{{ item.url }}" class="site-header__tool {{ item.active ? 'is-active' : '' }}">{{ item.title }}</a>
          {% endif %}
        {% endfor %}
        <a href="{{ umami_search_url }}" class="icon-btn" aria-label="{{ 'Search'|t }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
          {{ 'Search'|t }}
        </a>
      </div>
    </div>
  </header>

  <main>
    {% if umami_breadcrumb %}
      <div class="container breadcrumb-trail">
        {{ umami_breadcrumb }}
      </div>
    {% endif %}
    {{ page.content }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="site-footer__top">
        <div class="site-footer__brand">
          <h3>{{ site_name }}<span class="site-footer__mark">.</span></h3>
          {% if site_slogan %}
            <p>{{ site_slogan }}</p>
          {% endif %}
        </div>
        <div class="site-footer__groups">
          {{ page.footer }}
        </div>
      </div>
      <div class="site-footer__bottom">
        <span>&copy; {{ 'now'|date('Y') }} {{ site_name }}</span>
        <span><a href="{{ umami_contact_url }}">{{ 'Contact'|t }}</a></span>
      </div>
    </div>
  </footer>
</div>
